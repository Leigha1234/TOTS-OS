with org as (
  select id
  from organisations
  where name = :organisation_name
  limit 1
),

upsert_user as (
  insert into profiles (
    id,
    name,
    email,
    organisation_id
  )
  values (
    gen_random_uuid(),
    :name,
    :email,
    (select id from org)
  )
  on conflict (email)
  do update set
    name = excluded.name,
    organisation_id = excluded.organisation_id
  returning *
)

select
  p.id as user_id,
  p.name,
  p.email,
  p.organisation_id,
  o.name as organisation_name
from upsert_user p
left join organisations o
  on o.id = p.organisation_id;