const { data: profile, error } = await supabase
  .from("profiles")
  .select("organisation_id")
  .eq("id", user.id)
  .maybeSingle();

if (error) {
  console.warn("Profile fetch failed, retrying once...", error);

  const retry = await supabase
    .from("profiles")
    .select("organisation_id")
    .eq("id", user.id)
    .maybeSingle();

  if (!retry.data?.organisation_id) {
    toast.error("Profile not ready yet. Try again.");
    return;
  }

  setOrganisationId(retry.data.organisation_id);
  return;
}